{
  "name": "dental-clinic",
  "version": "1.0.0",
  "description": "Smart Clinic System - Dental Clinic Management",
  "main": "main/main.js",
  "scripts": {
    "dev": "cross-env PORT=8889 nextron",
    "dev:default": "nextron",
    "build": "next build",
    "build:win32": "nextron build --win --ia32",
    "build:win64": "nextron build --win --x64",
    "build:mac": "nextron build --mac --x64",
    "build:linux": "nextron build --linux",
    "postinstall": "electron-builder install-app-deps",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "electron-serve": "^1.3.0",
    "electron-store": "^8.2.0",
    "lucide-react": "^1.14.0",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0",
    "next": "^14.1.0",
    "nextron": "^9.0.0",
    "postcss": "^8.5.14",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0"
  }
}
